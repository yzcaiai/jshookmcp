*.har
jshook-capture-*
artifacts/
/workflows/
/plugins/

# Debug artifacts
debug/
debugger-sessions/
*.debug

# Temporary test/MCP artifacts
.tmp_mcp_artifacts/

# Ad-hoc test scripts (not the main tests/ suite)
test/

# Tool-generated spec/change directories
openspec/

# apk-packer fixture binaries (regenerated by build-signing-block-fixtures.ts)
tests/fixtures/apk-packer/*.apk
tests/fixtures/apk-packer/*.zip

# AI tool local configs — tracked in repo so agents can read, but not generated content
.context/
.github/prompts/
.github/skills/

# AI-generated documentation
CLAUDE.md
DESIGN.md

